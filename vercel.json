{
  "version": 2,
  "installCommand": "npm install && cd client && npm install",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/google-auth", "destination": "/api/google-auth.js" },
    { "source": "/api/google-callback", "destination": "/api/google-callback.js" },
    { "source": "/api/calendar-availability", "destination": "/api/calendar-availability.js" },
    { "source": "/api/calendar-book", "destination": "/api/calendar-book.js" },
    { "source": "/api/create-subscription-checkout", "destination": "/api/create-subscription-checkout.js" },
    { "source": "/api/create-booking-checkout", "destination": "/api/create-booking-checkout.js" },
    { "source": "/api/finalize-checkout", "destination": "/api/finalize-checkout.js" },
    { "source": "/api/realtime-session", "destination": "/api/realtime-session.js" },
    { "source": "/api/cancel-session", "destination": "/api/cancel-session.js" },
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/auth/(.*)", "destination": "/api/server" },
    { "source": "/calendar/(.*)", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
