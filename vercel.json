{
  "version": 2,
  "installCommand": "npm install && cd client && npm install",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/calendly-webhook", "destination": "/api/calendly-webhook.js" },
    { "source": "/api/calendly-auth", "destination": "/api/calendly/[action]?action=auth" },
    { "source": "/api/calendly-callback", "destination": "/api/calendly/[action]?action=callback" },
    { "source": "/api/calendly-event-types", "destination": "/api/calendly/[action]?action=event-types" },
    { "source": "/api/calendly-select-event-type", "destination": "/api/calendly/[action]?action=select-event-type" },
    { "source": "/api/calendly-event-type-summary", "destination": "/api/calendly/[action]?action=event-type-summary" },
    { "source": "/api/calendly-disconnect", "destination": "/api/calendly/[action]?action=disconnect" },
    { "source": "/api/create-subscription-checkout", "destination": "/api/create-subscription-checkout.js" },
    { "source": "/api/create-booking-checkout", "destination": "/api/create-booking-checkout.js" },
    { "source": "/api/finalize-checkout", "destination": "/api/finalize-checkout.js" },
    { "source": "/api/realtime-session", "destination": "/api/realtime-session.js" },
    { "source": "/api/ai-proxy", "destination": "/api/ai-proxy.js" },
    { "source": "/api/cancel-session", "destination": "/api/cancel-session.js" },
    { "source": "/api/checkr-webhook", "destination": "/api/utils/[action]?action=checkr-webhook" },
    { "source": "/api/verification/apply", "destination": "/api/verification/[action]?action=apply" },
    { "source": "/api/verification/application-status", "destination": "/api/verification/[action]?action=application-status" },
    { "source": "/api/billing-portal", "destination": "/api/utils/[action]?action=billing-portal" },
    { "source": "/api/mentor-room-slug", "destination": "/api/utils/[action]?action=mentor-room-slug" },
    { "source": "/api/booking-confirm-scheduled", "destination": "/api/booking-confirm-scheduled.js" },
    { "source": "/api/verification/start",                       "destination": "/api/verification/[action]?action=start" },
    { "source": "/api/verification/identity-start",              "destination": "/api/verification/[action]?action=identity-start" },
    { "source": "/api/verification/identity-confirm",            "destination": "/api/verification/[action]?action=identity-confirm" },
    { "source": "/api/verification/gov-id",                      "destination": "/api/verification/[action]?action=gov-id" },
    { "source": "/api/verification/professional-email-start",    "destination": "/api/verification/[action]?action=professional-email-start" },
    { "source": "/api/verification/professional-email-confirm",  "destination": "/api/verification/[action]?action=professional-email-confirm" },
    { "source": "/api/verification/linkedin",                    "destination": "/api/verification/[action]?action=linkedin" },
    { "source": "/api/verification/resume",                      "destination": "/api/verification/[action]?action=resume" },
    { "source": "/api/verification/expertise-interview",         "destination": "/api/verification/[action]?action=expertise-interview" },
    { "source": "/api/verification/reference-invite",            "destination": "/api/verification/[action]?action=reference-invite" },
    { "source": "/api/verification/reference-submit",            "destination": "/api/verification/[action]?action=reference-submit" },
    { "source": "/api/verification/finalize",                    "destination": "/api/verification/[action]?action=finalize" },
    { "source": "/api/admin/review-list",                        "destination": "/api/admin/review/[action]?action=list" },
    { "source": "/api/admin/review-decide",                      "destination": "/api/admin/review/[action]?action=decide" },
    { "source": "/api/admin/review-detail",                      "destination": "/api/admin/review/[action]?action=detail" },
    { "source": "/api/admin/mentor-flags",                       "destination": "/api/admin/review/[action]?action=mentor-flags" },
    { "source": "/api/cron/verification-retry",                  "destination": "/api/utils/[action]?action=verification-retry" },
    { "source": "/api/community-mod", "destination": "/api/community-mod.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://assets.calendly.com https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://assets.calendly.com https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://api.openai.com https://api.anthropic.com https://api.calendly.com https://calendly.com; frame-src https://js.stripe.com https://hooks.stripe.com https://calendly.com; media-src 'self' blob: data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
